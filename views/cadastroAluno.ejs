<!DOCTYPE html>
<html lang="pt-br">

<head>

  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <title>
    Cadastro de Aluno
  </title>

  <link rel="stylesheet" href="/css/cadastroAluno.css">

</head>

<body>

  <form action="/alunos/cadastro" method="POST">

    <h1>
      Cadastro de Aluno
    </h1>

    <div class="info">

      <p>
        A matrícula será gerada automaticamente.
      </p>

      <p>
        Padrão:
        <strong>
          ADS + Ano + Semestre + ID
        </strong>
      </p>

    </div>

    <% if(erro){ %>

      <div class="erro">

        <p>
          <%= erro %>
        </p>

      </div>

    <% } %>

    <div class="campo">

      <label>
        Nome do Aluno
      </label>

      <input
        type="text"
        name="nome"
        required
      >

    </div>

    <div class="campo">

      <label>
        E-mail
      </label>

      <input
        type="email"
        name="email"
        required
      >

    </div>

    <div class="campo">

      <label>
        Ano de Ingresso
      </label>

      <input
        type="number"
        name="anoIngresso"
        min="2000"
        max="2100"
        required
      >

    </div>

    <div class="campo">

      <label>
        Semestre de Ingresso
      </label>

      <select name="semestreIngresso">

        <option value="1">
          1° Semestre
        </option>

        <option value="2">
          2° Semestre
        </option>

      </select>

    </div>

    <div class="campo">

      <label>
        Semestre Atual
      </label>

      <input
        type="number"
        name="semestreAtual"
        min="1"
        max="10"
        value="1"
        required
      >

    </div>

    <div class="campo">

      <label>
        Formando
      </label>

      <select name="formando">

        <option value="false">
          Não
        </option>

        <option value="true">
          Sim
        </option>

      </select>

    </div>

    <button type="submit">

      Cadastrar Aluno

    </button>

  </form>

  <% if(sucesso){ %>

    <div class="modal">

      <div class="modal-content">

        <h2>
          Cadastro realizado com sucesso
        </h2>

        <p>
          Matrícula gerada:
        </p>

        <h3>
          <%= matriculaGerada %>
        </h3>

        <button onclick="fecharModal()">

          Fechar

        </button>

      </div>

    </div>

  <% } %>

  <script>

    function fecharModal(){

      document
        .querySelector('.modal')
        .style.display = 'none';

    }

  </script>

</body>

</html>